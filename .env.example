# ── Supabase (client) ─────────────────────────────────────────────
# Project URL and anon key from https://supabase.com/dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Optional escape hatch for Expo Go auth redirects.
# Normally the app computes this. If Expo logs an unusable localhost redirect,
# run `npx expo start --tunnel -c` or set the exact exp://.../--/auth/callback URL here.
# EXPO_PUBLIC_AUTH_REDIRECT_URL=exp://YOUR_EXPO_TUNNEL/--/auth/callback

# ── RevenueCat (client SDK keys, safe to expose) ──────────────────
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_...
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_...

# ──────────────────────────────────────────────────────────────────
# Server-side secrets — NEVER put these in EXPO_PUBLIC_* variables.
# Set them as Supabase Edge Function secrets instead:
#   supabase secrets set AI_PROVIDER=openai
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set GOOGLE_AI_API_KEY=...
#   supabase secrets set AI_MODEL=gpt-5-nano
#   supabase secrets set REVENUECAT_WEBHOOK_AUTH=some-long-random-string
# ──────────────────────────────────────────────────────────────────
